<?xml version="1.0" encoding="utf-8"?>
<!--
    Centralized color palette. Adjust these to recolor the app app-wide.
    - Brand colors (primary/secondary) drive toolbars, buttons, FABs.
    - Surface colors drive backgrounds; on-surface colors drive text/icons.
    - values-night/colors.xml overrides the surface family for dark mode.
    Layouts reference these via ?attr/colorPrimary, ?attr/colorSurface, etc.
    (set in themes.xml), or directly via @color/brand_secondary where needed.
-->
<resources>
	<!-- Legacy Material defaults (kept for compatibility; not used directly by app) -->
	<color name="purple_200">#BB86FC</color>
	<color name="purple_500">#6200EE</color>
	<color name="purple_700">#3700B3</color>
	<color name="teal_200">#03DAC5</color>
	<color name="teal_700">#018786</color>
	<color name="black">#000000</color>
	<color name="white">#FFFFFF</color>

	<!-- Brand / accent -->
	<color name="brand_primary">#1F6F8B</color>            <!-- toolbar, FAB, status bar -->
	<color name="brand_primary_variant">#14525F</color>   <!-- status bar shade -->
	<color name="brand_secondary">#B00020</color>         <!-- delete buttons, danger tint -->
	<color name="brand_on_primary">#FFFFFF</color>        <!-- text/icons on primary -->
	<color name="brand_on_secondary">#FFFFFF</color>      <!-- text/icons on secondary -->

	<!-- Surfaces (light mode defaults; overridden in values-night/colors.xml) -->
	<color name="brand_surface">#F5F5F5</color>            <!-- screen / card backgrounds -->
	<color name="brand_surface_variant">#E0E0E0</color>   <!-- image placeholders, status bar bg -->
	<color name="brand_on_surface">#1C1B1F</color>       <!-- primary text on surface -->
	<color name="brand_on_surface_variant">#49454F</color><!-- secondary text: paths, meta -->
	<color name="brand_outline">#79747E</color>          <!-- dividers, outline buttons -->
	<color name="surface_danger">#22B00020</color>          <!-- translucent danger overlay -->

	<!-- Launcher -->
	<color name="ic_launcher_background">#1F6F8B</color>
</resources>
