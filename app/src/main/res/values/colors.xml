<?xml version="1.0" encoding="utf-8"?>
<!--
    Centralized color palette. Adjust these to recolor the app app-wide.
    - Brand colors (primary/secondary) drive toolbars, buttons, FABs.
    - Surface colors drive backgrounds; on-surface colors drive text/icons.
    - values-night/colors.xml overrides the surface family for dark mode.
    Layouts reference these via ?attr/colorPrimary, ?attr/colorSurface, etc.
    (set in themes.xml), or directly via @color/brand_secondary where needed.
-->
<resources>
	<!-- Brand / accent -->
	<color name="brand_primary">#98D98E</color>            <!-- toolbar, FAB, status bar (mint) -->
	<color name="brand_primary_variant">#5E9C56</color>   <!-- status bar shade (darker mint) -->
	<color name="brand_secondary">#C0524A</color>         <!-- delete buttons, danger tint (warm red) -->
	<color name="brand_on_primary">#0E2A0D</color>        <!-- text/icons on primary (dark green) -->
	<color name="brand_on_secondary">#FFFFFF</color>      <!-- text/icons on secondary -->

	<!-- Surfaces (light mode defaults; overridden in values-night/colors.xml) -->
	<color name="brand_surface">#F4F7F4</color>            <!-- screen / card backgrounds -->
	<color name="brand_surface_variant">#E2E8E2</color>   <!-- image placeholders, status bar bg -->
	<color name="brand_on_surface">#1A1F1B</color>        <!-- primary text on surface -->
	<color name="brand_on_surface_variant">#4A544E</color><!-- secondary text: paths, meta -->
	<color name="brand_outline">#748176</color>           <!-- dividers, outline buttons -->

	<!-- Launcher -->
	<color name="ic_launcher_background">#98D98E</color>
</resources>
