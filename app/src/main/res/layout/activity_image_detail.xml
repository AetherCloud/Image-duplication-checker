<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:layout_width="match_parent"
	android:layout_height="match_parent">

	<com.google.android.material.appbar.AppBarLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content">

		<androidx.appcompat.widget.Toolbar
			android:id="@+id/toolbar"
			android:layout_width="match_parent"
			android:layout_height="?attr/actionBarSize"
			android:background="?attr/colorPrimary"
			app:navigationIcon="@drawable/ic_arrow_back_rounded"
			app:titleTextColor="?attr/colorOnPrimary" />
	</com.google.android.material.appbar.AppBarLayout>

	<ScrollView
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		app:layout_behavior="@string/appbar_scrolling_view_behavior">

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical">

			<ImageView
				android:id="@+id/imagePreview"
				android:layout_width="match_parent"
				android:layout_height="320dp"
				android:scaleType="fitCenter"
				android:contentDescription="@string/content_desc_thumbnail"
				android:background="?attr/colorSurfaceVariant"
				android:adjustViewBounds="true"
				android:clickable="true"
				android:focusable="true"
				android:foreground="?attr/selectableItemBackground" />

			<androidx.constraintlayout.widget.ConstraintLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:paddingHorizontal="16dp"
				android:paddingTop="16dp"
				android:paddingBottom="8dp">

				<androidx.constraintlayout.widget.Barrier
					android:id="@+id/labelBarrier"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					app:barrierDirection="end"
					app:constraint_referenced_ids="labelName,labelPath,labelResolution,labelSize,labelDateAdded,labelDateModified" />

				<TextView android:id="@+id/labelName"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="@string/detail_name"
					android:textStyle="bold"
					android:textSize="@dimen/text_size_label"
					android:paddingEnd="16dp"
					app:layout_constraintStart_toStartOf="parent"
					app:layout_constraintTop_toTopOf="@id/detailName"
					/>

				<TextView android:id="@+id/detailName"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:textAppearance="?attr/textAppearanceBodyMedium"
					android:textSize="@dimen/text_size_body"
					app:layout_constraintStart_toEndOf="@id/labelBarrier"
					app:layout_constraintEnd_toEndOf="parent"
					app:layout_constraintTop_toTopOf="parent" />

				<TextView android:id="@+id/labelPath"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="@string/detail_path"
					android:textStyle="bold"
					android:textSize="@dimen/text_size_label"
					android:paddingEnd="16dp"
					app:layout_constraintStart_toStartOf="parent"
					app:layout_constraintTop_toTopOf="@id/detailPath"
					/>

				<TextView android:id="@+id/detailPath"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:textAppearance="?attr/textAppearanceBodyMedium"
					android:textSize="@dimen/text_size_body"
					android:textIsSelectable="true"
					android:breakStrategy="simple"
					app:layout_constraintStart_toEndOf="@id/labelBarrier"
					app:layout_constraintEnd_toEndOf="parent"
					app:layout_constraintTop_toBottomOf="@id/detailName"
					android:layout_marginTop="8dp" />

				<TextView android:id="@+id/labelResolution"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="@string/detail_resolution"
					android:textStyle="bold"
					android:textSize="@dimen/text_size_label"
					android:paddingEnd="16dp"
					app:layout_constraintStart_toStartOf="parent"
					app:layout_constraintTop_toTopOf="@id/detailResolution"
					/>

				<TextView android:id="@+id/detailResolution"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:textAppearance="?attr/textAppearanceBodyMedium"
					android:textSize="@dimen/text_size_body"
					app:layout_constraintStart_toEndOf="@id/labelBarrier"
					app:layout_constraintEnd_toEndOf="parent"
					app:layout_constraintTop_toBottomOf="@id/detailPath"
					android:layout_marginTop="8dp" />

				<TextView android:id="@+id/labelSize"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="@string/detail_size"
					android:textStyle="bold"
					android:textSize="@dimen/text_size_label"
					android:paddingEnd="16dp"
					app:layout_constraintStart_toStartOf="parent"
					app:layout_constraintTop_toTopOf="@id/detailSize"
					/>

				<TextView android:id="@+id/detailSize"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:textAppearance="?attr/textAppearanceBodyMedium"
					android:textSize="@dimen/text_size_body"
					app:layout_constraintStart_toEndOf="@id/labelBarrier"
					app:layout_constraintEnd_toEndOf="parent"
					app:layout_constraintTop_toBottomOf="@id/detailResolution"
					android:layout_marginTop="8dp" />

				<TextView android:id="@+id/labelDateAdded"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="@string/detail_date_added"
					android:textStyle="bold"
					android:textSize="@dimen/text_size_label"
					android:paddingEnd="16dp"
					app:layout_constraintStart_toStartOf="parent"
					app:layout_constraintTop_toTopOf="@id/detailDateAdded"
					/>

				<TextView android:id="@+id/detailDateAdded"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:textAppearance="?attr/textAppearanceBodyMedium"
					android:textSize="@dimen/text_size_body"
					app:layout_constraintStart_toEndOf="@id/labelBarrier"
					app:layout_constraintEnd_toEndOf="parent"
					app:layout_constraintTop_toBottomOf="@id/detailSize"
					android:layout_marginTop="8dp" />

				<TextView android:id="@+id/labelDateModified"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="@string/detail_date_modified"
					android:textStyle="bold"
					android:textSize="@dimen/text_size_label"
					android:paddingEnd="16dp"
					app:layout_constraintStart_toStartOf="parent"
					app:layout_constraintTop_toTopOf="@id/detailDateModified"
					/>

				<TextView android:id="@+id/detailDateModified"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:textAppearance="?attr/textAppearanceBodyMedium"
					android:textSize="@dimen/text_size_body"
					app:layout_constraintStart_toEndOf="@id/labelBarrier"
					app:layout_constraintEnd_toEndOf="parent"
					app:layout_constraintTop_toBottomOf="@id/detailDateAdded"
					android:layout_marginTop="8dp" />

			</androidx.constraintlayout.widget.ConstraintLayout>

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="horizontal"
				android:paddingHorizontal="16dp"
				android:paddingBottom="24dp">

				<com.google.android.material.button.MaterialButton
					android:id="@+id/openButton"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:layout_marginEnd="8dp"
					android:text="@string/action_open"
					app:icon="@drawable/ic_open_in_new_rounded" />

				<com.google.android.material.button.MaterialButton
					android:id="@+id/deleteButton"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:layout_marginStart="8dp"
					android:text="@string/action_delete"
					android:backgroundTint="?attr/colorSecondary"
					app:icon="@drawable/ic_delete_rounded" />
			</LinearLayout>
		</LinearLayout>
	</ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
